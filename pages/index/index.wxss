/* 日历卡片 */
.calendar-card {
  background: #fff;
  margin: 20rpx;
  border-radius: 16rpx;
  padding: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.calendar-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
}

.month-selector {
  display: flex;
  align-items: center;
  font-size: 36rpx;
  font-weight: 600;
}

.arrow {
  margin-left: 10rpx;
  font-size: 24rpx;
  color: #999;
}

.today-btn {
  padding: 10rpx 30rpx;
  background: var(--primary);
  color: #fff;
  border-radius: 30rpx;
  font-size: 26rpx;
}

/* 星期标题 */
.week-header {
  display: grid;
  grid-template-columns: repeat(7, 1fr);
  text-align: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.week-day {
  font-size: 28rpx;
  color: #333;
}

.week-day.weekend {
  color: #ff4d4f;
}

/* 日期网格 */
.date-grid {
  display: grid;
  grid-template-columns: repeat(7, 1fr);
  gap: 10rpx;
  padding: 20rpx 0;
}

.date-cell {
  aspect-ratio: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  border-radius: 12rpx;
  position: relative;
  padding: 10rpx 0;
}

.date-cell.other-month {
  opacity: 0.3;
}

.date-cell.today {
  background: var(--primary-light);
}

.date-cell.selected {
  background: var(--primary);
  color: #fff;
}

.date-cell.selected .lunar-text,
.date-cell.selected .holiday-text {
  color: rgba(255, 255, 255, 0.8);
}

.date-number {
  font-size: 30rpx;
  font-weight: 500;
}

.duty-dots {
  display: flex;
  gap: 6rpx;
  margin-top: 6rpx;
}

.duty-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
}

.duty-dot.shift-morning { background: #ff9500; }
.duty-dot.shift-afternoon { background: #1890ff; }
.duty-dot.shift-night { background: #722ed1; }
.duty-dot.shift-overday { background: #52c41a; }

.lunar-text, .holiday-text {
  font-size: 20rpx;
  color: #999;
  margin-top: 4rpx;
}

.holiday-text {
  color: #ff4d4f;
}

/* 班次详情卡片 */
.duty-detail-card {
  margin: 0 20rpx 20rpx;
}

.edit-btn {
  color: var(--primary);
  font-size: 28rpx;
}

.duty-list {
  margin-top: 20rpx;
}

.duty-item {
  background: #f8f8f8;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  border-left: 8rpx solid #ddd;
}

.duty-item.shift-morning { border-left-color: #ff9500; }
.duty-item.shift-afternoon { border-left-color: #1890ff; }
.duty-item.shift-night { border-left-color: #722ed1; }
.duty-item.shift-overday { border-left-color: #52c41a; }

.duty-main {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 16rpx;
}

.duty-time {
  display: flex;
  flex-direction: column;
}

.shift-name {
  font-size: 32rpx;
  font-weight: 600;
  margin-bottom: 8rpx;
}

.time-range {
  font-size: 26rpx;
  color: #666;
}

.overnight-tag {
  display: inline-block;
  padding: 4rpx 12rpx;
  background: #722ed1;
  color: #fff;
  font-size: 20rpx;
  border-radius: 6rpx;
  margin-top: 8rpx;
  width: fit-content;
}

.duty-info {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 20rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid #e5e5e5;
}

.user-info {
  display: flex;
  align-items: center;
}

.user-avatar {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  margin-right: 16rpx;
}

.user-name {
  font-size: 28rpx;
  color: #333;
}

.duty-actions {
  display: flex;
  gap: 16rpx;
}

.check-info {
  margin-top: 20rpx;
  padding: 16rpx;
  background: #fff;
  border-radius: 8rpx;
}

.check-row {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
}

.check-row:last-child {
  margin-bottom: 0;
}

.check-label {
  font-size: 26rpx;
  color: #666;
  width: 100rpx;
}

.check-time {
  font-size: 26rpx;
  color: #333;
}

.tag-late, .tag-early {
  margin-left: 16rpx;
  padding: 4rpx 12rpx;
  background: #ff4d4f;
  color: #fff;
  font-size: 20rpx;
  border-radius: 6rpx;
}

.work-hours {
  margin-left: auto;
  font-size: 26rpx;
  color: var(--primary);
}

.empty-duties {
  padding: 60rpx 0;
}

/* 快捷操作 */
.quick-actions {
  margin: 0 20rpx 40rpx;
}

/* 换班表单 */
.swap-form {
  padding: 30rpx;
}
