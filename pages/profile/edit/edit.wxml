<!--pages/profile/edit/edit.wxml-->
<view class="page-container">
  <view class="form-card">
    <!-- 头像 -->
    <view class="avatar-section" bindtap="chooseAvatar">
      <image class="avatar" src="{{userInfo.avatarUrl || '/images/default-avatar.png'}}" mode="aspectFill"/>
      <text class="avatar-tip">点击更换头像</text>
    </view>
    
    <van-cell-group title="基本信息">
      <van-field
        label="真实姓名"
        value="{{userInfo.realName}}"
        placeholder="请输入真实姓名"
        required
        bind:change="onRealNameChange"
      />
      <van-field
        label="部门"
        value="{{userInfo.department}}"
        placeholder="请输入部门"
        bind:change="onDepartmentChange"
      />
      <van-field
        label="手机号"
        value="{{userInfo.phone}}"
        placeholder="请输入手机号"
        type="number"
        bind:change="onPhoneChange"
      />
    </van-cell-group>
  </view>
  
  <view class="submit-bar">
    <van-button type="primary" block bindtap="saveProfile">保存</van-button>
  </view>
  
  <van-toast id="van-toast" />
</view>
