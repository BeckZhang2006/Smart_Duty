<view class="page-container">
  <!-- 登录页面 -->
  <view wx:if="{{!isRegistering}}" class="login-section">
    <view class="logo-area">
      <view class="logo">
        <text class="logo-icon">📋</text>
      </view>
      <text class="app-name">值班管理系统</text>
      <text class="app-desc">高效便捷的排班打卡解决方案</text>
    </view>

    <view class="login-box">
      <text class="login-title">欢迎使用</text>
      <text class="login-tip">请授权登录以继续使用</text>

      <!-- 新接口 -->
      <button 
        wx:if="{{canIUseGetUserProfile}}"
        class="login-btn"
        bindtap="getUserProfile"
      >
        <text class="btn-icon">👤</text>
        <text>微信一键登录</text>
      </button>

      <!-- 旧接口兼容 -->
      <button 
        wx:else
        class="login-btn"
        open-type="getUserInfo"
        bindgetuserinfo="getUserInfo"
      >
        <text class="btn-icon">👤</text>
        <text>微信一键登录</text>
      </button>

      <text class="privacy-tip">登录即表示您同意《用户协议》和《隐私政策》</text>
    </view>
  </view>

  <!-- 注册页面 -->
  <view wx:else class="register-section">
    <view class="register-header">
      <image class="user-avatar" src="{{userInfo.avatarUrl}}" mode="aspectFill"/>
      <text class="welcome-text">欢迎，{{userInfo.nickName}}</text>
      <text class="register-tip">请完善以下信息完成注册</text>
    </view>

    <view class="form-box">
      <van-cell-group inset>
        <van-field
          label="真实姓名"
          placeholder="请输入真实姓名"
          value="{{form.realName}}"
          bind:change="onRealNameChange"
          required
          clearable
        />
        <van-field
          label="手机号"
          placeholder="请输入手机号"
          value="{{form.phone}}"
          bind:change="onPhoneChange"
          type="number"
          maxlength="11"
          required
          clearable
        />
        <van-field
          label="部门"
          placeholder="请输入所属部门（选填）"
          value="{{form.department}}"
          bind:change="onDepartmentChange"
          clearable
        />
      </van-cell-group>

      <view class="form-actions">
        <button class="submit-btn" bindtap="submitRegister">完成注册</button>
        <button class="back-btn" bindtap="backToLogin">返回</button>
      </view>
    </view>
  </view>

  <van-toast id="van-toast" />
</view>
