/* 排班详情页样式 */

.page-container {
  min-height: 100vh;
  background: var(--bg);
  padding-bottom: constant(safe-area-inset-bottom);
  padding-bottom: env(safe-area-inset-bottom);
}

/* 日历卡片 */
.calendar-card {
  background: #fff;
  margin: 20rpx;
  border-radius: 16rpx;
  padding: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.calendar-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
}

.month-selector {
  display: flex;
  align-items: center;
  font-size: 36rpx;
  font-weight: 600;
  color: var(--text);
}

.arrow {
  margin-left: 10rpx;
  font-size: 24rpx;
  color: var(--text-light);
}

.today-btn {
  padding: 10rpx 30rpx;
  background: var(--primary);
  color: #fff;
  border-radius: 30rpx;
  font-size: 26rpx;
}

/* 星期标题 */
.week-header {
  display: grid;
  grid-template-columns: repeat(7, 1fr);
  text-align: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid var(--border);
}

.week-day {
  font-size: 28rpx;
  color: var(--text);
}

.week-day.weekend {
  color: var(--danger);
}

/* 日期网格 */
.date-grid {
  display: grid;
  grid-template-columns: repeat(7, 1fr);
  gap: 10rpx;
  padding: 20rpx 0;
}

.date-cell {
  aspect-ratio: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  border-radius: 12rpx;
  position: relative;
  padding: 10rpx 0;
}

.date-cell.other-month {
  opacity: 0.3;
}

.date-cell.today {
  background: var(--primary-light);
}

.date-cell.selected {
  background: var(--primary);
  color: #fff;
}

.date-number {
  font-size: 30rpx;
  font-weight: 500;
}

.duty-dots {
  display: flex;
  gap: 6rpx;
  margin-top: 6rpx;
}

.duty-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
}

/* 排班详情卡片 */
.schedule-detail-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin: 0 20rpx 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid var(--border);
}

.card-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text);
}

.edit-btn {
  color: var(--primary);
  font-size: 28rpx;
}

/* 排班列表 */
.schedule-list {
  margin-top: 20rpx;
}

.schedule-item {
  background: #f8f8f8;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  border-left: 8rpx solid var(--primary);
}

.schedule-main {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 16rpx;
}

.shift-name {
  font-size: 32rpx;
  font-weight: 600;
  margin-bottom: 8rpx;
  color: var(--text);
}

.time-range {
  font-size: 26rpx;
  color: var(--text-secondary);
}

.schedule-info {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 20rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid var(--border);
}

.user-info {
  display: flex;
  align-items: center;
}

.user-avatar {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  margin-right: 16rpx;
}

.user-name {
  font-size: 28rpx;
  color: var(--text);
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 40rpx;
  color: var(--text-light);
}

/* 班次颜色 */
.shift-morning { background: #fff7e6; color: #ff9500; }
.shift-afternoon { background: #e6f7ff; color: #1890ff; }
.shift-night { background: #f9f0ff; color: #722ed1; }
.shift-overday { background: #f6ffed; color: #52c41a; }
