<!--pages/admin/schedule.wxml-->
<view class="page-container">
  <!-- 月份选择 -->
  <view class="header-bar">
    <view class="month-selector" bindtap="showMonthPicker">
      <text class="month-text">{{currentYear}}年{{currentMonth}}月</text>
      <text class="arrow">▼</text>
    </view>
    <van-button type="primary" size="small" bindtap="goToCreate">新建排班</van-button>
  </view>
  
  <!-- 统计信息 -->
  <view class="stats-bar">
    <view class="stat-item">
      <text class="stat-value">{{stats.total}}</text>
      <text class="stat-label">总排班</text>
    </view>
    <view class="stat-item">
      <text class="stat-value">{{stats.pending}}</text>
      <text class="stat-label">待打卡</text>
    </view>
    <view class="stat-item">
      <text class="stat-value">{{stats.completed}}</text>
      <text class="stat-label">已完成</text>
    </view>
  </view>
  
  <!-- 排班列表 -->
  <view class="schedule-list">
    <view wx:if="{{schedules.length > 0}}">
      <view wx:for="{{schedules}}" wx:key="_id" class="schedule-card">
        <view class="schedule-header">
          <text class="schedule-date">{{item.date}}</text>
          <van-tag type="{{getStatusType(item.status)}}">{{getStatusText(item.status)}}</van-tag>
        </view>
        <view class="schedule-body">
          <view class="info-row">
            <text class="info-label">班次：</text>
            <text class="info-value shift-name">{{item.shiftInfo.name || '未知'}}</text>
          </view>
          <view class="info-row">
            <text class="info-label">时间：</text>
            <text class="info-value">{{item.shiftInfo.startTime}} - {{item.shiftInfo.endTime}}</text>
          </view>
          <view class="info-row">
            <text class="info-label">人员：</text>
            <view class="user-tag">
              <image class="mini-avatar" src="{{item.userInfo.avatarUrl || '/images/default-avatar.png'}}" mode="aspectFill"/>
              <text class="info-value">{{item.userInfo.realName || '未知'}}</text>
            </view>
          </view>
        </view>
        <view class="schedule-footer">
          <van-button type="primary" size="mini" plain bindtap="editSchedule" data-id="{{item._id}}" custom-style="margin-right: 20rpx;">编辑</van-button>
          <van-button type="danger" size="mini" plain bindtap="deleteSchedule" data-id="{{item._id}}">删除</van-button>
        </view>
      </view>
    </view>
    <view wx:else class="empty-state">
      <van-empty description="暂无排班数据" />
    </view>
  </view>
  
  <!-- 月份选择弹窗 -->
  <van-popup show="{{showMonthPicker}}" position="bottom" bind:close="hideMonthPicker">
    <van-picker
      show-toolbar
      title="选择月份"
      columns="{{monthColumns}}"
      default-index="{{currentMonthIndex}}"
      bind:confirm="onMonthConfirm"
      bind:cancel="hideMonthPicker"
    />
  </van-popup>
  
  <van-toast id="van-toast" />
</view>
