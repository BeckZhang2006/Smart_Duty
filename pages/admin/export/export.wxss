.page-container {
  padding: 20rpx 20rpx 140rpx;
  background: #f5f5f5;
  min-height: 100vh;
}

.header {
  padding: 30rpx 20rpx;
  text-align: center;
}

.title {
  font-size: 40rpx;
  font-weight: 700;
  color: #333;
  margin-bottom: 12rpx;
}

.subtitle {
  font-size: 26rpx;
  color: #999;
}

.section {
  margin-bottom: 20rpx;
}

.card {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 24rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

/* 导出类型选择 */
.radio-group {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.radio-item {
  padding: 24rpx;
  background: #f8f8f8;
  border-radius: 12rpx;
  border: 2rpx solid transparent;
  transition: all 0.3s;
}

.radio-item.active {
  background: #e8f5e9;
  border-color: #07c160;
}

/* 日期选择 */
.date-picker-row {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.date-picker {
  flex: 1;
  background: #f8f8f8;
  border-radius: 12rpx;
  padding: 20rpx;
}

.date-label {
  display: block;
  font-size: 24rpx;
  color: #999;
  margin-bottom: 8rpx;
}

.date-value {
  font-size: 32rpx;
  color: #333;
  font-weight: 500;
}

.date-separator {
  font-size: 28rpx;
  color: #999;
}

/* 月份选择 */
.month-picker {
  background: #f8f8f8;
  border-radius: 12rpx;
  padding: 24rpx;
}

.month-value {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.month-text {
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
}

.month-hint {
  font-size: 24rpx;
  color: #999;
  margin-top: 8rpx;
}

/* 人员选择 */
.user-selector {
  display: flex;
  align-items: center;
  background: #f8f8f8;
  border-radius: 12rpx;
  padding: 24rpx;
}

.user-label {
  font-size: 28rpx;
  color: #666;
  margin-right: 20rpx;
}

.user-value {
  flex: 1;
  font-size: 32rpx;
  color: #333;
  font-weight: 500;
}

.user-arrow {
  font-size: 28rpx;
  color: #999;
}

.user-hint {
  font-size: 24rpx;
  color: #999;
  margin-top: 16rpx;
  padding-left: 8rpx;
}

/* 信息卡片 */
.info-card {
  background: linear-gradient(135deg, #e3f2fd 0%, #f3e5f5 100%);
}

.info-content {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.info-item {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.info-label {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
}

.info-text {
  font-size: 26rpx;
  color: #666;
  line-height: 1.6;
}

/* 结果卡片 */
.result-card {
  background: linear-gradient(135deg, #e8f5e9 0%, #c8e6c9 100%);
  border: 2rpx solid #07c160;
}

.result-content {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.result-file {
  display: flex;
  align-items: center;
  background: rgba(255, 255, 255, 0.8);
  border-radius: 12rpx;
  padding: 20rpx;
}

.file-icon {
  font-size: 48rpx;
  margin-right: 16rpx;
}

.file-name {
  flex: 1;
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
  word-break: break-all;
}

.result-actions {
  display: flex;
  justify-content: center;
  gap: 20rpx;
}

.result-hint {
  text-align: center;
  font-size: 24rpx;
  color: #666;
  background: rgba(255, 255, 255, 0.6);
  border-radius: 8rpx;
  padding: 12rpx;
}

/* 操作栏 */
.action-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20rpx 30rpx;
  background: #fff;
  border-top: 1rpx solid #eee;
  z-index: 100;
}
