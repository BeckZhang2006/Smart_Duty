<view class="page-container">
  <view class="header">
    <view class="title">📊 数据导出</view>
    <view class="subtitle">选择导出类型和时间范围，生成Excel报表</view>
  </view>

  <!-- 导出类型选择 -->
  <view class="section card">
    <view class="section-title">导出类型</view>
    <van-radio-group value="{{exportType}}" bind:change="onExportTypeChange">
      <view class="radio-group">
        <view 
          wx:for="{{exportTypes}}" 
          wx:key="value"
          class="radio-item {{exportType === item.value ? 'active' : ''}}"
          data-value="{{item.value}}"
        >
          <van-radio name="{{item.value}}" icon-size="16px">
            {{item.label}}
          </van-radio>
        </view>
      </view>
    </van-radio-group>
  </view>

  <!-- 日期范围选择 - 排班表和打卡记录 -->
  <view class="section card" wx:if="{{exportType !== 'exportStatistics'}}">
    <view class="section-title">📅 日期范围</view>
    <view class="date-picker-row">
      <view class="date-picker">
        <text class="date-label">开始日期</text>
        <picker mode="date" value="{{startDate}}" bindchange="onStartDateChange">
          <view class="date-value">{{startDate || '请选择'}}</view>
        </picker>
      </view>
      <text class="date-separator">至</text>
      <view class="date-picker">
        <text class="date-label">结束日期</text>
        <picker mode="date" value="{{endDate}}" bindchange="onEndDateChange">
          <view class="date-value">{{endDate || '请选择'}}</view>
        </picker>
      </view>
    </view>
  </view>

  <!-- 月份选择 - 统计数据 -->
  <view class="section card" wx:if="{{exportType === 'exportStatistics'}}">
    <view class="section-title">📅 选择月份</view>
    <view class="month-picker">
      <picker mode="date" fields="month" value="{{month}}" bindchange="onMonthChange">
        <view class="month-value">
          <text class="month-text">{{month}}</text>
          <text class="month-hint">点击选择月份</text>
        </view>
      </picker>
    </view>
  </view>

  <!-- 人员选择 - 打卡记录可选 -->
  <view class="section card" wx:if="{{exportType === 'exportCheckRecords'}}">
    <view class="section-title">👤 人员选择（可选）</view>
    <view class="user-selector" bindtap="onSelectUser">
      <text class="user-label">选择人员</text>
      <text class="user-value">{{userName}}</text>
      <text class="user-arrow">></text>
    </view>
    <view class="user-hint" wx:if="{{!userId}}">不选择则导出所有人员的记录</view>
  </view>

  <!-- 导出说明 -->
  <view class="section card info-card">
    <view class="section-title">ℹ️ 导出说明</view>
    <view class="info-content">
      <view class="info-item" wx:if="{{exportType === 'exportSchedule'}}">
        <text class="info-label">排班表包含：</text>
        <text class="info-text">日期、班次名称、值班人员、部门、班次时间、状态</text>
      </view>
      <view class="info-item" wx:if="{{exportType === 'exportCheckRecords'}}">
        <text class="info-label">打卡记录包含：</text>
        <text class="info-text">日期、人员、部门、签到时间、签退时间、工时、状态、迟到/早退情况</text>
      </view>
      <view class="info-item" wx:if="{{exportType === 'exportStatistics'}}">
        <text class="info-label">统计数据包含：</text>
        <text class="info-text">人员、排班次数、已完成、完成率、总工时、迟到次数</text>
      </view>
      <view class="info-item">
        <text class="info-label">导出格式：</text>
        <text class="info-text">Excel (.xlsx) 文件，支持在电脑或手机上查看</text>
      </view>
    </view>
  </view>

  <!-- 导出结果 -->
  <view class="section card result-card" wx:if="{{exportResult}}">
    <view class="section-title">✅ 导出成功</view>
    <view class="result-content">
      <view class="result-file">
        <text class="file-icon">📄</text>
        <text class="file-name">{{exportResult.filename}}</text>
      </view>
      <view class="result-actions">
        <van-button type="primary" size="small" bindtap="previewFile">
          预览文件
        </van-button>
        <van-button type="info" size="small" bindtap="copyDownloadUrl">
          复制链接
        </van-button>
        <van-button type="default" size="small" bindtap="saveFile">
          保存文件
        </van-button>
      </view>
      <view class="result-hint">
        <text>提示：临时链接有效期约10分钟，请及时下载保存</text>
      </view>
    </view>
  </view>

  <!-- 导出按钮 -->
  <view class="action-bar">
    <van-button 
      type="primary" 
      block
      loading="{{loading}}"
      disabled="{{loading}}"
      bindtap="doExport"
    >
      {{loading ? '导出中...' : '开始导出'}}
    </van-button>
  </view>
</view>

<!-- 人员选择弹窗 -->
<van-popup
  show="{{showUserPicker}}"
  round
  position="bottom"
  bind:close="onUserPickerClose"
>
  <van-picker
    show-toolbar
    title="选择人员"
    columns="{{staffList}}"
    value-key="realName"
    bind:change="onUserPickerChange"
    bind:confirm="onUserPickerConfirm"
    bind:cancel="onUserPickerClose"
  />
</van-popup>

<van-toast id="van-toast" />
