<!--pages/admin/users.wxml-->
<view class="page-container">
  <!-- 搜索栏 -->
  <view class="search-bar">
    <van-search
      value="{{searchKeyword}}"
      placeholder="搜索姓名"
      bind:change="onSearchChange"
      bind:search="onSearch"
    />
  </view>
  
  <!-- 统计信息 -->
  <view class="stats-bar">
    <view class="stat-item">
      <text class="stat-value">{{stats.total}}</text>
      <text class="stat-label">总人数</text>
    </view>
    <view class="stat-item">
      <text class="stat-value">{{stats.admin}}</text>
      <text class="stat-label">管理员</text>
    </view>
    <view class="stat-item">
      <text class="stat-value">{{stats.staff}}</text>
      <text class="stat-label">员工</text>
    </view>
  </view>
  
  <!-- 人员列表 -->
  <view class="user-list">
    <view wx:if="{{filteredUsers.length > 0}}">
      <view wx:for="{{filteredUsers}}" wx:key="_id" class="user-card">
        <image class="user-avatar" src="{{item.avatarUrl || '/images/default-avatar.png'}}" mode="aspectFill"/>
        <view class="user-info">
          <view class="user-header">
            <text class="user-name">{{item.realName || '未设置姓名'}}</text>
            <van-tag type="{{item.role === 'admin' ? 'danger' : 'primary'}}" size="mini">
              {{item.role === 'admin' ? '管理员' : '员工'}}
            </van-tag>
          </view>
          <text class="user-dept">{{item.department || '未设置部门'}}</text>
          <text class="user-phone" wx:if="{{item.phone}}">{{item.phone}}</text>
        </view>
        <view class="user-actions">
          <van-button type="primary" size="mini" plain bindtap="editUser" data-id="{{item._id}}">编辑</van-button>
        </view>
      </view>
    </view>
    <view wx:else class="empty-state">
      <van-empty description="暂无人员数据" />
    </view>
  </view>
  
  <van-toast id="van-toast" />
</view>
