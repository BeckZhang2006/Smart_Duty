.page-container {
  padding: 20rpx 20rpx 200rpx;
}

.card {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

/* 信息卡片样式 */
.info-card {
  background: linear-gradient(135deg, #07c160 0%, #05a050 100%);
  color: #fff;
}

.info-title {
  font-size: 32rpx;
  font-weight: 600;
  margin-bottom: 20rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.3);
}

.info-content {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.info-item {
  display: flex;
  align-items: center;
}

.info-label {
  font-size: 28rpx;
  opacity: 0.9;
  width: 140rpx;
}

.info-value {
  font-size: 28rpx;
  font-weight: 500;
}

/* 表单卡片样式 */
.form-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 40rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.form-item {
  margin-bottom: 30rpx;
}

.form-label {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 16rpx;
}

.required {
  color: #ff4d4f;
}

.picker-cell {
  background: #f8f8f8;
  border-radius: 12rpx;
}

.picker-cell.placeholder {
  color: #999;
}

/* 预览卡片样式 */
.preview-card {
  background: #f8f8f8;
}

.preview-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 20rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid #e0e0e0;
}

.preview-item {
  display: flex;
  align-items: flex-start;
  margin-bottom: 16rpx;
}

.preview-label {
  font-size: 28rpx;
  color: #666;
  width: 160rpx;
  flex-shrink: 0;
}

.preview-value {
  font-size: 28rpx;
  color: #333;
  flex: 1;
}

.time-slots {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.time-slot {
  font-size: 26rpx;
  color: #07c160;
  background: rgba(7, 193, 96, 0.1);
  padding: 8rpx 16rpx;
  border-radius: 8rpx;
}

/* 操作按钮 */
.action-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20rpx 30rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background: #fff;
  border-top: 1rpx solid #f0f0f0;
}

/* Vant组件样式覆盖 - 使用类名选择器 */
.van-cell {
  background: transparent !important;
  padding: 20rpx !important;
}

.van-cell__title {
  font-size: 28rpx;
}
