.page-container {
  padding: 20rpx 20rpx 140rpx;
  background: #f5f5f5;
  min-height: 100vh;
}

.header {
  padding: 30rpx 20rpx;
  text-align: center;
}

.title {
  font-size: 40rpx;
  font-weight: 700;
  color: #333;
  margin-bottom: 12rpx;
}

.subtitle {
  font-size: 26rpx;
  color: #999;
}

.section {
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 24rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.template-actions {
  display: flex;
  gap: 30rpx;
}

.action-link {
  font-size: 26rpx;
  color: #07c160;
}

/* 日期选择 */
.date-picker-row {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.date-picker {
  flex: 1;
  background: #f8f8f8;
  border-radius: 12rpx;
  padding: 20rpx;
}

.date-label {
  display: block;
  font-size: 24rpx;
  color: #999;
  margin-bottom: 8rpx;
}

.date-value {
  font-size: 32rpx;
  color: #333;
  font-weight: 500;
}

.date-separator {
  font-size: 28rpx;
  color: #999;
}

/* 周模板 */
.week-template {
  background: #f8f8f8;
  border-radius: 12rpx;
  overflow: hidden;
}

.template-header {
  display: flex;
  background: #e8f5e9;
  padding: 24rpx 20rpx;
  font-size: 28rpx;
  font-weight: 600;
  color: #07c160;
}

.template-row {
  display: flex;
  align-items: center;
  padding: 24rpx 20rpx;
  border-bottom: 1rpx solid #eee;
}

.template-row:last-child {
  border-bottom: none;
}

.day-name {
  width: 120rpx;
  font-size: 30rpx;
  font-weight: 500;
  color: #333;
}

.staff-picker {
  flex: 1;
  padding: 0 10rpx;
}

.picker-value {
  background: #fff;
  border: 2rpx solid #ddd;
  border-radius: 8rpx;
  padding: 16rpx 20rpx;
  font-size: 28rpx;
  color: #333;
  text-align: center;
}

.picker-value.empty {
  color: #999;
  border-style: dashed;
}

/* 班次说明 */
.info-card {
  background: linear-gradient(135deg, #e3f2fd 0%, #f3e5f5 100%);
}

.shift-info {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.shift-item {
  background: rgba(255, 255, 255, 0.8);
  border-radius: 12rpx;
  padding: 20rpx;
}

.shift-name {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 8rpx;
}

.shift-time {
  font-size: 26rpx;
  color: #07c160;
  margin-right: 20rpx;
}

.shift-desc {
  font-size: 24rpx;
  color: #999;
}

/* 操作栏 */
.action-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20rpx 30rpx;
  background: #fff;
  border-top: 1rpx solid #eee;
  z-index: 100;
}
