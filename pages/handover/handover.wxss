.duty-card {
  background: linear-gradient(135deg, #722ed1 0%, #531dab 100%);
  color: #fff;
  margin: 20rpx;
  border-radius: 20rpx;
}

.duty-title {
  font-size: 36rpx;
  font-weight: 600;
  margin-bottom: 20rpx;
}

.duty-info {
  display: flex;
  flex-direction: column;
  font-size: 28rpx;
  opacity: 0.9;
}

.duty-date {
  margin-bottom: 8rpx;
}

.section-card {
  margin: 0 20rpx 20rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  margin-bottom: 20rpx;
  color: #333;
}

van-checkbox {
  margin-bottom: 16rpx;
}

.item-list, .todo-list {
  margin-top: 20rpx;
}

.item-row, .todo-row {
  display: flex;
  align-items: center;
  background: #f8f8f8;
  border-radius: 12rpx;
  padding: 16rpx;
  margin-bottom: 16rpx;
}

.item-info {
  flex: 1;
}

.item-count {
  width: 200rpx;
}

.item-delete, .delete-icon {
  padding: 16rpx;
  font-size: 32rpx;
}

.todo-row {
  justify-content: space-between;
}

.todo-row .done {
  text-decoration: line-through;
  color: #999;
}

.empty-items {
  text-align: center;
  padding: 40rpx;
  color: #999;
}

.signature-area {
  height: 200rpx;
  border: 2rpx dashed #ddd;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #fafafa;
}

.signature-area image {
  max-width: 100%;
  max-height: 100%;
}

.signature-placeholder {
  color: #999;
}

.submit-area {
  margin: 40rpx 20rpx;
  padding-bottom: constant(safe-area-inset-bottom);
  padding-bottom: env(safe-area-inset-bottom);
}

.dialog-content {
  padding: 30rpx;
}

.signature-pad {
  display: flex;
  flex-direction: column;
  height: 100%;
}

.signature-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #eee;
}

.clear-btn {
  color: #ff4d4f;
}

.signature-canvas {
  flex: 1;
  background: #fff;
}

.signature-footer {
  display: flex;
  justify-content: space-around;
  padding: 30rpx;
  border-top: 1rpx solid #eee;
}
