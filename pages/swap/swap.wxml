<!--pages/swap/swap.wxml-->
<view class="page-container">
  <!-- 标签页 -->
  <van-tabs active="{{activeTab}}" bind:change="onTabChange" sticky>
    <van-tab title="我的申请" name="sent">
      <view class="tab-content">
        <view wx:if="{{sentList.length > 0}}">
          <view wx:for="{{sentList}}" wx:key="_id" class="swap-card">
            <view class="swap-header">
              <text class="swap-date">申请时间：{{formatDateTime(item.createTime)}}</text>
              <van-tag type="{{getStatusType(item.status)}}">{{getStatusText(item.status)}}</van-tag>
            </view>
            <view class="swap-body">
              <view class="user-row">
                <image class="user-avatar" src="{{item.toUser.avatarUrl || '/images/default-avatar.png'}}" mode="aspectFill"/>
                <text class="user-name">申请与 {{item.toUser.realName || '未知'}} 换班</text>
              </view>
              <view class="reason-box" wx:if="{{item.reason}}">
                <text class="reason-label">换班理由：</text>
                <text class="reason-text">{{item.reason}}</text>
              </view>
            </view>
            <view class="swap-footer" wx:if="{{item.status === 'pending'}}">
              <van-button type="danger" size="small" bindtap="cancelSwap" data-id="{{item._id}}">取消申请</van-button>
            </view>
          </view>
        </view>
        <view wx:else class="empty-state">
          <van-empty description="暂无换班申请" />
        </view>
      </view>
    </van-tab>
    
    <van-tab title="收到申请" name="received">
      <view class="tab-content">
        <view wx:if="{{receivedList.length > 0}}">
          <view wx:for="{{receivedList}}" wx:key="_id" class="swap-card">
            <view class="swap-header">
              <text class="swap-date">申请时间：{{formatDateTime(item.createTime)}}</text>
              <van-tag type="{{getStatusType(item.status)}}">{{getStatusText(item.status)}}</van-tag>
            </view>
            <view class="swap-body">
              <view class="user-row">
                <image class="user-avatar" src="{{item.fromUser.avatarUrl || '/images/default-avatar.png'}}" mode="aspectFill"/>
                <text class="user-name">{{item.fromUser.realName || '未知'}} 申请与您换班</text>
              </view>
              <view class="reason-box" wx:if="{{item.reason}}">
                <text class="reason-label">换班理由：</text>
                <text class="reason-text">{{item.reason}}</text>
              </view>
            </view>
            <view class="swap-footer" wx:if="{{item.status === 'pending'}}">
              <van-button type="primary" size="small" bindtap="approveSwap" data-id="{{item._id}}" custom-class="btn-approve">同意</van-button>
              <van-button type="default" size="small" bindtap="rejectSwap" data-id="{{item._id}}">拒绝</van-button>
            </view>
          </view>
        </view>
        <view wx:else class="empty-state">
          <van-empty description="暂无收到的申请" />
        </view>
      </view>
    </van-tab>
  </van-tabs>
  
  <!-- 申请换班按钮 -->
  <view class="fab-btn" bindtap="goToApply">
    <text class="fab-icon">+</text>
    <text>申请换班</text>
  </view>
  
  <!-- 拒绝理由弹窗 -->
  <van-dialog
    use-slot
    title="拒绝理由"
    show="{{showRejectDialog}}"
    show-cancel-button
    bind:confirm="confirmReject"
    bind:cancel="cancelReject"
  >
    <van-field
      type="textarea"
      value="{{rejectRemark}}"
      placeholder="请输入拒绝理由（可选）"
      bind:change="onRejectRemarkChange"
    />
  </van-dialog>
  
  <van-toast id="van-toast" />
</view>
