/* 换班申请表单页样式 */

.page-container {
  min-height: 100vh;
  background: var(--bg);
  padding-bottom: constant(safe-area-inset-bottom);
  padding-bottom: env(safe-area-inset-bottom);
}

/* 表单卡片 */
.form-card {
  background: #fff;
  border-radius: 16rpx;
  margin: 20rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

/* 提交栏 */
.submit-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 20rpx 30rpx;
  padding-bottom: calc(20rpx + constant(safe-area-inset-bottom));
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background: #fff;
  box-shadow: 0 -2rpx 12rpx rgba(0, 0, 0, 0.05);
}

/* 选择器弹窗头部 */
.picker-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid var(--border);
}

.picker-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text);
}

.picker-close {
  font-size: 28rpx;
  color: var(--text-light);
}

/* 班次列表 */
.duty-list {
  max-height: 60vh;
  padding: 20rpx;
}

.duty-item {
  background: #f8f8f8;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  transition: all 0.3s;
}

.duty-item.selected {
  background: var(--primary-light);
  border: 2rpx solid var(--primary);
}

.duty-info-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.duty-date {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text);
}

.duty-shift {
  font-size: 28rpx;
  color: var(--primary);
  font-weight: 500;
}

.duty-time {
  font-size: 24rpx;
  color: var(--text-secondary);
}

/* 用户列表 */
.user-list {
  max-height: 60vh;
  padding: 20rpx;
}

.user-item {
  display: flex;
  align-items: center;
  background: #f8f8f8;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  transition: all 0.3s;
}

.user-item.selected {
  background: var(--primary-light);
  border: 2rpx solid var(--primary);
}

.user-item .user-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  margin-right: 20rpx;
}

.user-item .user-info {
  display: flex;
  flex-direction: column;
  flex: 1;
}

.user-item .user-name {
  font-size: 30rpx;
  font-weight: 500;
  color: var(--text);
  margin-bottom: 8rpx;
}

.user-item .user-dept {
  font-size: 24rpx;
  color: var(--text-secondary);
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 40rpx;
  color: var(--text-light);
}
